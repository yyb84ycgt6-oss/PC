# AI Studio Integration Configuration

# ====================================
# Google Gemini API
# ====================================

# Your Gemini API key from https://aistudio.google.com/
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# Model selection
REACT_APP_GEMINI_MODEL=gemini-2.0-flash

# Enable vision capabilities (image analysis)
REACT_APP_GEMINI_VISION=true

# Temperature for creative responses (0-1)
REACT_APP_GEMINI_TEMPERATURE=0.7

# ====================================
# Integration Behavior
# ====================================

# Enable auto-save of generated code
REACT_APP_AUTO_SAVE=false

# Maximum number of tasks to keep in history
REACT_APP_MAX_HISTORY=50

# ====================================
# Development
# ====================================

# Debug logging
REACT_APP_DEBUG=false

# Development server port
VITE_PORT=5173
